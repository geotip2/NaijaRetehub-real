rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if false; // Admin only in real app
    }
    match /courses/{courseId} {
      allow read: if true;
      allow write: if false; // Admin only in real app
    }
  }
}
